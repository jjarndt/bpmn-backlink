<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="defs_order"
                  targetNamespace="http://example.net/bpmn">
  <bpmn:process id="orderProcess" isExecutable="true">
    <bpmn:startEvent id="start"/>
    <bpmn:serviceTask id="placeOrder" name="Place order"
                      camunda:delegateExpression="${orderDelegate}"/>
    <bpmn:serviceTask id="takePayment" name="Take payment"
                      camunda:class="net.example.delegate.PaymentDelegate"/>
    <bpmn:endEvent id="end"/>
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="placeOrder"/>
    <bpmn:sequenceFlow id="f2" sourceRef="placeOrder" targetRef="takePayment"/>
    <bpmn:sequenceFlow id="f3" sourceRef="takePayment" targetRef="end"/>
  </bpmn:process>
</bpmn:definitions>
