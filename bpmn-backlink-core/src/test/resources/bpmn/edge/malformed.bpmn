<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="defs_malformed"
                  targetNamespace="http://example.net/bpmn">
  <bpmn:process id="malformedProcess" isExecutable="true">
    <bpmn:serviceTask id="unclosed" name="Never closed"
                      camunda:class="net.example.delegate.NeverReachedDelegate">
  </bpmn:process>
