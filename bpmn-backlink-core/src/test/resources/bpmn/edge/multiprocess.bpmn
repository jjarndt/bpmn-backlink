<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="defs_multi"
                  targetNamespace="http://example.net/bpmn">
  <bpmn:collaboration id="collab">
    <bpmn:participant id="participantOne" processRef="processOne"/>
    <bpmn:participant id="participantTwo" processRef="processTwo"/>
  </bpmn:collaboration>
  <bpmn:process id="processOne" isExecutable="true">
    <bpmn:serviceTask id="one" name="One"
                      camunda:class="net.example.delegate.OneDelegate"/>
  </bpmn:process>
  <bpmn:process id="processTwo" isExecutable="true">
    <bpmn:serviceTask id="two" name="Two"
                      camunda:delegateExpression="${twoBean}"/>
  </bpmn:process>
</bpmn:definitions>
