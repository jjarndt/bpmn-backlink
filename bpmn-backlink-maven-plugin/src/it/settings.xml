<?xml version="1.0" encoding="UTF-8"?>
<!--
    Optional settings file for the invoker integration test. It points the
    sub-build at the staging repository populated by invoker:install while still
    allowing the regular local repository as a fallback. No mirrors are forced,
    so the test stays self-contained and offline-friendly.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
    <localRepository>@localRepositoryUrl@</localRepository>
</settings>
